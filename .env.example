# ─────────────────────────────────────────────────────────────────────────────
# ListAI Environment Variables
# Copy this file to .env and fill in all values before starting the backend.
# The app will exit at startup with a clear error if any variable is missing.
# ─────────────────────────────────────────────────────────────────────────────

# ── Clerk (https://clerk.com) ─────────────────────────────────────────────────
# Backend secret key — never expose to frontend
CLERK_SECRET_KEY=sk_live_...

# Frontend publishable key — safe to expose, used by React
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Anthropic Claude API (https://console.anthropic.com) ─────────────────────
# Used for vision (item identification), pricing analysis, title/description
# generation, and shipping suggestions. Model: claude-opus-4-5
ANTHROPIC_API_KEY=sk-ant-...

# ── Cloudinary (https://cloudinary.com) ──────────────────────────────────────
# Used for image upload, processing (crop/pad/enhance), and CDN hosting
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# ── Pinecone (https://pinecone.io) ────────────────────────────────────────────
# Vector database for RAG-based style memory (past titles + descriptions)
# Create an index with dimension=1024 and metric=cosine
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=listai-memory

# ── Voyage AI (https://dash.voyageai.com) ────────────────────────────────────
# Embedding model for RAG: voyage-3-lite (1024 dimensions)
# Free tier: 200M tokens/month — sign up at dash.voyageai.com
VOYAGE_API_KEY=pa-...

# ── Serper (https://serper.dev) ───────────────────────────────────────────────
# Google Search API for pricing research (recent eBay sold listings, resale values)
SERPER_API_KEY=...

# ── eBay Developer Program (https://developer.ebay.com) ──────────────────────
# Create an app at developer.ebay.com to get App ID, Dev ID, and Cert ID
# Auth token: generate via eBay's Auth'n'Auth flow or Developer Portal
EBAY_APP_ID=YourApp-12345678-abcd-1234-abcd-1234567890ab
EBAY_DEV_ID=12345678-abcd-1234-abcd-1234567890ab
EBAY_CERT_ID=YourCert-abcd-1234-abcd-12345678901a
EBAY_AUTH_TOKEN=v^1.1#i^1#f^0#r^0#p^3#I^3#t^...
# Set to "true" for sandbox testing, "false" for live production
EBAY_SANDBOX_MODE=true

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string — e.g. from Railway, Supabase, or local
DATABASE_URL=postgresql://user:password@localhost:5432/listai

# Redis connection string — e.g. from Railway, Upstash, or local
# Required for BullMQ background job queues
REDIS_URL=redis://localhost:6379

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Frontend (set in frontend/.env) ──────────────────────────────────────────
# Vite only exposes env vars prefixed with VITE_
# VITE_CLERK_PUBLISHABLE_KEY is already listed above
